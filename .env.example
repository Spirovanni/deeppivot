# ============================================================
# DeepPivot — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000          # Production: https://deeppivots.com

# ─── Database (Neon Postgres) ────────────────────────────────
# https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Authentication (Clerk) ──────────────────────────────────
# https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...               # Clerk Dashboard → Webhooks → signing secret

# Clerk redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─── ElevenLabs (AI Voice Interviews) ────────────────────────
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=sk_...
NEXT_PUBLIC_ELEVENLABS_API_KEY=sk_...        # Same key — exposed for signed URL requests from browser
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=agent_...    # Conversational AI agent ID
ELEVENLABS_DEFAULT_VOICE_ID=                 # Optional: default TTS voice ID
ELEVENLABS_DEFAULT_MODEL_ID=eleven_turbo_v2  # Optional: default TTS model

# ─── LLM Providers ───────────────────────────────────────────
# Set LLM_PROVIDER to "anthropic" or "openai" to select which to use
LLM_PROVIDER=anthropic

# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# https://platform.openai.com → API Keys (alternative/fallback)
OPENAI_API_KEY=                              # Optional, for OpenAI/OpenRouter models. Format: sk-proj-...

# OpenAI Embeddings (semantic search, RAG) — uses OPENAI_API_KEY above
EMBEDDING_MODEL=text-embedding-3-small      # or text-embedding-3-large for higher accuracy
EMBEDDING_DIMENSIONS=1536                   # 256–3072 for 3-small; 256–3072 for 3-large

# Optional additional providers
GOOGLE_API_KEY=                              # Gemini
MISTRAL_API_KEY=                             # Mistral
XAI_API_KEY=                                 # Grok
AZURE_OPENAI_API_KEY=                        # Azure OpenAI
PERPLEXITY_API_KEY=                          # Perplexity (research features in TaskMaster)
OLLAMA_API_KEY=                              # Remote Ollama servers

# ─── Cloudflare R2 (Storage) ─────────────────────────────────
# https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=deeppivots

# ─── Inngest (Background Jobs) ───────────────────────────────
# https://app.inngest.com → your app → Manage → Keys
INNGEST_EVENT_KEY=                           # Required in production
INNGEST_SIGNING_KEY=                         # Required in production

# Admin export signed links (deeppivot-313) — or uses CLERK_SECRET_KEY as fallback
EXPORT_SIGNING_SECRET=                       # 32+ char secret for CSV download tokens

# ─── Deepgram (Transcription) ────────────────────────────────
# https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=

# ─── HuggingFace (BERT Archetype Classification) ─────────────
# https://huggingface.co → Settings → Access Tokens
HUGGINGFACE_API_KEY=hf_...
HUGGINGFACE_ARCHETYPE_MODEL=typeform/distilbert-base-uncased-mnli

# ─── Polar (Billing) ─────────────────────────────────────────
# https://polar.sh/dashboard → Settings → API Keys
POLAR_ACCESS_TOKEN=polar_at_...          # Polar API access token (server-side only)
POLAR_WEBHOOK_SECRET=whsec_...           # Polar Dashboard → Webhooks → signing secret
POLAR_ENV=production                     # "sandbox" for test mode, "production" for live
# Product IDs from Polar Dashboard → Products
POLAR_PRODUCT_ID_PRO=                    # Pro tier Polar product ID
POLAR_PRODUCT_ID_ENTERPRISE=             # Enterprise tier Polar product ID

# ─── Stripe (Legacy — replaced by Polar) ─────────────────────
# NEXT_PUBLIC_STRIPE_PUBLISH_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# ─── Sentry (Error Tracking & Performance) ───────────────────
# https://sentry.io → your project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
SENTRY_DSN=https://...@o0.ingest.sentry.io/0   # Same value — server-side alias
SENTRY_ORG=your-org-slug                        # Sentry CLI (source map uploads)
SENTRY_PROJECT=deeppivot                        # Sentry project slug
SENTRY_AUTH_TOKEN=sntrys_...                    # Sentry → Settings → Auth Tokens

# ─── PostHog (Product Analytics) ─────────────────────────────
# https://app.posthog.com → your project → Settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # EU: https://eu.i.posthog.com

# ─── Axiom (Structured Logging) ──────────────────────────────
# https://axiom.co → your org → Settings → API Tokens
AXIOM_TOKEN=xaat-...
AXIOM_DATASET=deeppivot                         # Axiom dataset name

# ─── Vercel (CI/CD tooling — optional) ───────────────────────
# https://vercel.com/account/tokens
AUTH_BEARER_TOKEN=                           # Vercel personal access token
TEAM_ID_VERCEL=                              # Vercel team ID (Settings → General)
PROJECT_ID_VERCEL=                           # Vercel project ID (Settings → General)

# ─── Salesforce Integration (WDB Partner) ────────────────────
# https://login.salesforce.com → Setup → Connected Apps
SALESFORCE_LOGIN_URL=https://login.salesforce.com  # Use .sandbox.salesforce.com for sandbox
SALESFORCE_USERNAME=                               # API/integration user login
SALESFORCE_PASSWORD=                               # Password (security token appended)
SALESFORCE_SECURITY_TOKEN=                         # Appended to password for username-password flow
SALESFORCE_CLIENT_ID=                              # Connected App Consumer Key
SALESFORCE_CLIENT_SECRET=                          # Connected App Consumer Secret

# ─── Legacy / Unused (kept for reference) ────────────────────
# VAPI_API_KEY=                              # Vapi (v1 pipeline, replaced by ElevenLabs)
# VAPI_INTERVIEW_ASSISTANT_ID=
# VAPI_DEFAULT_VOICE_ID=
# PLAYHT_API_KEY=                            # PlayHT TTS (alternative to ElevenLabs TTS)
# PLAYHT_USER_ID=
# PLAYHT_DEFAULT_VOICE_ID=
# GITHUB_API_KEY=                            # GitHub (TaskMaster import/export)

# ── Upstash Redis (Rate Limiting) ─────────────────────────────────────────────
# Required for API rate limiting in production. Get from console.upstash.com
UPSTASH_REDIS_REST_URL=                      # https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=                    # your-upstash-token

# ── E2E Testing (Playwright) ──────────────────────────────────────────────────
# Set to your preview/staging URL in CI; defaults to http://localhost:3000
# PLAYWRIGHT_BASE_URL=https://your-preview.vercel.app
